# Base URL for REST calls. In dev we use a relative "/api" so Vite's proxy forwards to the
# backend (avoids CORS). In production set this to your API origin, e.g. https://api.example.com
VITE_API_URL=/api

# Socket.IO server URL. Empty string = same origin (works with the Vite proxy in dev and
# Nginx in prod). Override to an absolute URL if the socket server is on a different host.
VITE_SOCKET_URL=
